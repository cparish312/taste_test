# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/tastetest?schema=public"

# OpenAI API key (server-side only)
OPENAI_API_KEY="sk-..."

# Default model for task spec and card batches (fast/cheap)
OPENAI_MODEL="gpt-5.4-mini"

# Smarter model for creating/updating inference dimensions and belief state
OPENAI_DIMENSION_MODEL="gpt-5.1"

# Smarter model for the final answer / recommendation
OPENAI_FINAL_MODEL="gpt-5.1"

# Model for predicting user swipe responses (after 5+ answers)
OPENAI_PREDICTION_MODEL="gpt-5.4-mini"

# Optional: improves image search fallback (Wikipedia is used first, no key needed)
# UNSPLASH_ACCESS_KEY=""
